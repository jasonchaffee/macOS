#!/usr/bin/env zsh

BASE_DIR=$( cd $( dirname ${(%):-%x} ) &> /dev/null && pwd )
source ${BASE_DIR}/../lib/colors

echo -e "${GREEN}Uninstalling${NC} iTerm2 preferences"
echo ""
echo -e "${YELLOW}Note:${NC} iTerm2 preferences are not automatically reverted."
echo "  To restore defaults: iTerm2 → Preferences → Import a different export, or reset via: defaults delete com.googlecode.iterm2"
