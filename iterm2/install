#!/usr/bin/env zsh

BASE_DIR=$( cd $( dirname ${(%):-%x} ) &> /dev/null && pwd )
source ${BASE_DIR}/../lib/colors

EXPORT_FILE="${BASE_DIR}/iterm2.itermexport"

echo -e "${GREEN}Installing${NC} iTerm2 preferences"
echo ""
echo -e "${YELLOW}Manual step required:${NC}"
echo "  In iTerm2: General → Preferences → Import"
echo "  Select: ${EXPORT_FILE}"
